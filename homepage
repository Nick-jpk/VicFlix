<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>NickFlix</title>

<style>

body{
margin:0;
font-family:Arial;
background:#141414;
color:white;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 40px;
background:#000;
}

.logo{
font-size:28px;
color:red;
font-weight:bold;
}

nav a{
color:white;
margin-left:20px;
text-decoration:none;
}

.hero{
height:400px;
background:url("https://images.unsplash.com/photo-1489599849927-2ee91cede3ba") center/cover;
display:flex;
flex-direction:column;
justify-content:center;
padding:40px;
}

.hero h1{
font-size:50px;
}

button{
padding:10px 20px;
border:none;
background:red;
color:white;
font-size:16px;
cursor:pointer;
border-radius:4px;
}

.section{
padding:20px 40px;
}

.row{
display:flex;
overflow-x:auto;
}

.card{
min-width:200px;
margin-right:15px;
}

.card img{
width:100%;
border-radius:6px;
}

.song{
background:#222;
padding:10px;
border-radius:6px;
margin:10px 0;
}

</style>
</head>

<body>

<header>
<div class="logo">NickFlix</div>
<nav>
<a href="#">Home</a>
<a href="#">Movies</a>
<a href="#">Songs</a>
</nav>
</header>

<div class="hero">
<h1>Unlimited Movies & Music</h1>
<p>Watch trailers and listen to songs</p>
<button onclick="playTrailer()">Play Trailer</button>
</div>

<div class="section">
<h2>Trending Movies</h2>

<div class="row">

<div class="card">
<img src="https://m.media-amazon.com/images/I/51K8ouYrHeL.jpg">
</div>

<div class="card">
<img src="https://m.media-amazon.com/images/I/71niXI3lxlL.jpg">
</div>

<div class="card">
<img src="https://m.media-amazon.com/images/I/81p+xe8cbnL.jpg">
</div>

<div class="card">
<img src="https://m.media-amazon.com/images/I/71c05lTE03L.jpg">
</div>

</div>
</div>

<div class="section">
<h2>Top Songs</h2>

<div class="song">
<p>Song 1</p>
<audio controls>
<source src="song.mp3" type="audio/mpeg">
</audio>
</div>

<div class="song">
<p>Song 2</p>
<audio controls>
<source src="song2.mp3" type="audio/mpeg">
</audio>
</div>

</div>

<script>

function playTrailer(){
window.open("https://www.youtube.com")
}

</script>

</body>
</html>
